## ЁЯТ░ R Case Study: Comparing MoM vs. MLE for Stock Returns {.smaller}

:::: {style="font-size:50px"}
::: {.columns}
::: {.column width="52%"}

```{r}
#| echo: true
#| message: false
#| warning: false
#| eval: true

library(tidyverse)
library(tidyquant)
library(knitr)
library(MASS)  # for fitdistr (MLE)

# Download 3 years of monthly returns
symbols <- c("AAPL", "XOM", "JPM")
prices <- tq_get(symbols,
                 from = "2021-01-01",
                 to = "2023-12-31")

returns <- prices %>%
  group_by(symbol) %>%
  tq_transmute(select = adjusted,
               mutate_fun = periodReturn,
               period = "monthly",
               col_rename = "return") %>%
  mutate(return_pct = return * 100)

# MoM estimates: mu_hat = Ybar, sigma^2_hat = S^2
mom_est <- returns %>%
  group_by(symbol) %>%
  summarise(
    n = n(),
    mu_MoM    = mean(return_pct),
    sigma_MoM = sd(return_pct),
    .groups = "drop"
  )

kable(mom_est, digits = 3,
      caption = "Method of Moments Estimates (Monthly Returns, %)")
```

:::
::: {.column width="48%"}

```{r}
#| echo: true
#| message: false
#| warning: false
#| eval: true
#| fig-width: 5.5
#| fig-height: 5

# MLE for normal: mu_MLE = Ybar, sigma_MLE^2 = (1/n)*sum(yi-ybar)^2
mle_est <- returns %>%
  group_by(symbol) %>%
  summarise(
    mu_MLE    = mean(return_pct),
    sigma_MLE = sd(return_pct) * sqrt((n()-1)/n()),
    .groups = "drop"
  )

# MLE sigma uses n in denominator, MoM uses n-1
comparison <- mom_est %>%
  left_join(mle_est, by = "symbol") %>%
  mutate(sigma_bias = sigma_MoM - sigma_MLE)

# Visualise: fitted normal densities vs empirical
returns %>%
  left_join(mle_est, by = "symbol") %>%
  ggplot(aes(x = return_pct)) +
  geom_histogram(aes(y = after_stat(density)),
                 bins = 12, fill = "steelblue",
                 alpha = 0.5, color = "white") +
  stat_function(fun = dnorm,
    args = list(mean = mle_est$mu_MLE[1],
                sd   = mle_est$sigma_MLE[1]),
    color = "red", linewidth = 1.2, linetype = "dashed") +
  facet_wrap(~symbol, ncol = 1, scales = "free_x") +
  labs(title = "Monthly Returns vs. MLE Normal Fit",
       subtitle = "Red dashed: MLE N(╬╝╠В, ╧Г╠В┬▓)",
       x = "Monthly Return (%)", y = "Density") +
  theme_minimal(base_size = 10)
```

:::
:::
::::

